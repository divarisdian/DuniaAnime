    <a href="#" onclick="showSection('home');return false;" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-blue-600 flex items-center justify-center">
        <iconify-icon icon="solar:star-bold" class="text-white text-sm"></iconify-icon>
      </div>
      <span class="font-heading font-semibold text-sm tracking-tight">Dunia Anime</span>
    </a>
    <div class="hidden md:flex items-center gap-6">
      <a href="#anime-list" class="text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition-colors duration-150">Anime</a>
      <a href="#characters" class="text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition-colors duration-150">Karakter</a>
      <a href="#episodes" class="text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition-colors duration-150">Episode</a>
      <a href="#news" class="text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition-colors duration-150">Berita</a>
