  <!-- Login Modal -->
  <div id="loginModal" class="fixed inset-0 z-[70] modal-overlay hidden items-center justify-center p-4">
    <div class="bg-[#0a0a0a] border border-white/5 rounded-2xl w-full max-w-md p-8 relative anim-in">
      <button onclick="closeModal('login')" class="absolute top-4 right-4 text-neutral-500 hover:text-white transition">
        <iconify-icon icon="solar:close-circle-bold" class="text-2xl"></iconify-icon>
      </button>
      <div class="text-center mb-8">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500 to-blue-600 flex items-center justify-center mx-auto mb-4 pulse-glow">
          <iconify-icon icon="solar:star-bold" class="text-white text-2xl"></iconify-icon>
        </div>
        <h3 class="font-heading text-2xl font-semibold tracking-tight">Selamat Datang</h3>
        <p class="text-neutral-500 text-sm mt-1">Masuk ke Dunia Anime</p>
      </div>
      <form onsubmit="handleLogin(event)" class="space-y-4">
        <div>
          <label class="text-xs uppercase tracking-widest text-neutral-500 mb-1 block">Email</label>
          <input type="email" id="loginEmail" required class="input-field w-full px-4 py-3 rounded-xl text-sm text-white" placeholder="kamu@anime.com">
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-neutral-500 mb-1 block">Password</label>
          <div class="relative">
            <input type="password" id="loginPassword" required class="input-field w-full px-4 py-3 rounded-xl text-sm text-white pr-10" placeholder="••••••••">
            <button type="button" onclick="togglePassword('loginPassword')" class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-white">
              <iconify-icon icon="solar:eye-bold" class="text-lg"></iconify-icon>
            </button>
          </div>
        </div>
        <div id="loginError" class="text-red-400 text-xs hidden"></div>
        <button type="submit" class="btn-primary w-full py-3 rounded-xl text-xs font-bold uppercase tracking-widest text-white">
          Masuk
        </button>
      </form>
      <p class="text-center text-neutral-500 text-sm mt-6">
        Belum punya akun? <button onclick="switchModal('login','register')" class="text-purple-400 hover:text-purple-300 transition">Daftar</button>
      </p>
    </div>
  </div>

  <!-- Register Modal -->
  <div id="registerModal" class="fixed inset-0 z-[70] modal-overlay hidden items-center justify-center p-4">
    <div class="bg-[#0a0a0a] border border-white/5 rounded-2xl w-full max-w-md p-8 relative anim-in">
      <button onclick="closeModal('register')" class="absolute top-4 right-4 text-neutral-500 hover:text-white transition">
        <iconify-icon icon="solar:close-circle-bold" class="text-2xl"></iconify-icon>
      </button>
      <div class="text-center mb-8">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500 to-blue-600 flex items-center justify-center mx-auto mb-4 pulse-glow">
          <iconify-icon icon="solar:user-plus-bold" class="text-white text-2xl"></iconify-icon>
        </div>
        <h3 class="font-heading text-2xl font-semibold tracking-tight">Buat Akun</h3>
        <p class="text-neutral-500 text-sm mt-1">Bergabung dengan komunitas anime</p>
      </div>
      <form onsubmit="handleRegister(event)" class="space-y-4">
        <div>
          <label class="text-xs uppercase tracking-widest text-neutral-500 mb-1 block">Username</label>
          <input type="text" id="regUsername" required class="input-field w-full px-4 py-3 rounded-xl text-sm text-white" placeholder="narutofan99">
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-neutral-500 mb-1 block">Email</label>
          <input type="email" id="regEmail" required class="input-field w-full px-4 py-3 rounded-xl text-sm text-white" placeholder="kamu@anime.com">
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-neutral-500 mb-1 block">Password</label>
          <div class="relative">
            <input type="password" id="regPassword" required minlength="6" class="input-field w-full px-4 py-3 rounded-xl text-sm text-white pr-10" placeholder="Minimal 6 karakter">
            <button type="button" onclick="togglePassword('regPassword')" class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-white">
              <iconify-icon icon="solar:eye-bold" class="text-lg"></iconify-icon>
            </button>
          </div>
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-neutral-500 mb-1 block">Anime Favorit</label>
          <select id="regFavAnime" class="input-field w-full px-4 py-3 rounded-xl text-sm text-white">
            <option value="Naruto">Naruto</option>
            <option value="One Piece">One Piece</option>
            <option value="Demon Slayer">Demon Slayer</option>
            <option value="Jujutsu Kaisen">Jujutsu Kaisen</option>
            <option value="Attack on Titan">Attack on Titan</option>
            <option value="Dragon Ball">Dragon Ball</option>
            <option value="My Hero Academia">My Hero Academia</option>
          </select>
        </div>
        <div id="regError" class="text-red-400 text-xs hidden"></div>
        <button type="submit" class="btn-primary w-full py-3 rounded-xl text-xs font-bold uppercase tracking-widest text-white">
          Daftar Sekarang
        </button>
      </form>
      <p class="text-center text-neutral-500 text-sm mt-6">
        Sudah punya akun? <button onclick="switchModal('register','login')" class="text-purple-400 hover:text-purple-300 transition">Masuk</button>
      </p>
    </div>
  </div>

