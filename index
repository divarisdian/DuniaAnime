    <section class="py-24 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row gap-12 items-center">
          <div class="md:w-1/2 relative">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden relative">
