            '<div class="absolute inset-0 bg-gradient-to-t from-[#080808] via-transparent to-transparent"></div>' +
            '<div class="absolute top-3 right-3 flex items-center gap-1 bg-black/60 backdrop-blur-sm px-2 py-1 rounded-full">' +
              '<iconify-icon icon="solar:star-bold" class="text-yellow-400 text-xs"></iconify-icon>' +
              '<span class="text-xs font-medium">' + a.rating + '</span>' +
            '</div>' +
            '<div class="absolute top-3 left-3">' +
              '<span class="text-[10px] uppercase tracking-widest bg-purple-500/20 text-purple-300 border border-purple-500/30 px-2 py-0.5 rounded-full">' + a.status + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="p-5">' +
            '<h3 class="font-heading text-lg font-semibold tracking-tight mb-2 group-hover:text-purple-300 transition-colors">' + a.title + '</h3>' +
            '<p class="text-neutral-500 text-xs leading-relaxed line-clamp-2 mb-3">' + a.desc + '</p>' +
            '<div class="flex items-center justify-between">' +
              '<div class="flex gap-1 flex-wrap">' +
                a.genre.slice(0, 2).map(function(g) { return '<span class="tag">' + g + '</span>'; }).join('') +
              '</div>' +
              '<span class="text-neutral-600 text-xs">' + a.episodes + ' ep</span>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
    }

    function renderCharacters() {
      var grid = document.getElementById('characterGrid');
      grid.innerHTML = characterData.map(function(c, i) {
        return '<div class="card-hover rounded-2xl overflow-hidden bg-[#080808] group text-center anim-in" style="animation-delay:' + (i * 0.05) + 's">' +
          '<div class="aspect-square relative overflow-hidden">' +
            '<img src="' + c.img + '" alt="' + c.name + '" class="w-full h-full object-cover anime-card-img">' +
            '<div class="absolute inset-0 bg-gradient-to-t from-[#080808] via-transparent to-transparent"></div>' +
          '</div>' +
          '<div class="p-3 -mt-8 relative z-10">' +
            '<p class="font-heading text-sm font-semibold tracking-tight group-hover:text-purple-300 transition-colors">' + c.name + '</p>' +
            '<p class="text-neutral-500 text-[10px] uppercase tracking-widest mt-0.5">' + c.anime + ' · ' + c.role + '</p>' +
          '</div>' +
        '</div>';
      }).join('');
    }

    var currentTab = 'naruto';
    function renderEpisodes(tab) {
      currentTab = tab || currentTab;
      var list = document.getElementById('episodeList');
      var eps = episodeData[currentTab] || [];
      list.innerHTML = eps.map(function(e, i) {
        return '<div class="episode-row flex items-center gap-4 p-4 rounded-xl border border-white/[0.03] transition-colors cursor-pointer anim-in" style="animation-delay:' + (i * 0.05) + 's" onclick="playEpisode(' + e.ep + ')">' +
          '<div class="w-10 h-10 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center shrink-0">' +
            '<iconify-icon icon="solar:play-bold" class="text-purple-400 text-sm"></iconify-icon>' +
          '</div>' +
          '<div class="flex-1 min-w-0">' +
            '<p class="text-sm font-medium truncate">Episode ' + e.ep + ': ' + e.title + '</p>' +
            '<p class="text-neutral-600 text-xs mt-0.5">' + e.date + '</p>' +
          '</div>' +
          '<span class="text-neutral-600 text-xs shrink-0">' + e.duration + '</span>' +
        '</div>';
      }).join('');
    }

    function switchTab(tab) {
      document.querySelectorAll('[id^="tab-"]').forEach(function(el) {
        el.classList.remove('tab-active');
        el.classList.add('text-neutral-500');
      });
      document.getElementById('tab-' + tab).classList.add('tab-active');
      document.getElementById('tab-' + tab).classList.remove('text-neutral-500');
      renderEpisodes(tab);
    }

    function filterAnime() {
      var search = document.getElementById('searchAnime').value;
      var genre = document.getElementById('filterGenre').value;
      renderAnimeGrid(search, genre);
    }

    // ===================== ANIME DETAIL =====================
    function showAnimeDetail(title) {
      var anime = animeData.find(function(a) { return a.title === title; });
      if (!anime) return;
      var user = getCurrentUser();
      var db = getDB();
      var watched = false;
      if (user) {
        var entry = db.find(function(d) { return d.email === user.email && d.anime === anime.title; });
        if (entry) watched = true;
      }
      document.getElementById('detailContent').innerHTML =
        '<div class="rounded-2xl overflow-hidden mb-8 relative">' +
          '<img src="' + anime.image + '" class="w-full h-64 md:h-96 object-cover">' +
          '<div class="absolute inset-0 bg-gradient-to-t from-[#030303] via-[#030303]/50 to-transparent"></div>' +
          '<div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">' +
            '<div class="flex flex-wrap gap-2 mb-3">' +
              anime.genre.map(function(g) { return '<span class="tag">' + g + '</span>'; }).join('') +
            '</div>' +
            '<h1 class="font-heading text-3xl md:text-5xl font-semibold tracking-tighter">' + anime.title + '</h1>' +
          '</div>' +
        '</div>' +
        '<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">' +
          '<div class="p-4 rounded-xl bg-white/[0.02] border border-white/5 text-center">' +
            '<div class="font-heading text-2xl font-light tracking-tighter">' + anime.episodes + '</div>' +
            '<div class="text-neutral-500 text-xs uppercase tracking-widest mt-1">Episode</div>' +
          '</div>' +
          '<div class="p-4 rounded-xl bg-white/[0.02] border border-white/5 text-center">' +
            '<div class="font-heading text-2xl font-light tracking-tighter">' + anime.rating + '</div>' +
            '<div class="text-neutral-500 text-xs uppercase tracking-widest mt-1">Rating</div>' +
          '</div>' +
          '<div class="p-4 rounded-xl bg-white/[0.02] border border-white/5 text-center">' +
            '<div class="font-heading text-2xl font-light tracking-tighter">' + anime.year + '</div>' +
            '<div class="text-neutral-500 text-xs uppercase tracking-widest mt-1">Tahun</div>' +
          '</div>' +
          '<div class="p-4 rounded-xl bg-white/[0.02] border border-white/5 text-center">' +
            '<div class="font-heading text-lg font-light tracking-tighter">' + anime.status + '</div>' +
            '<div class="text-neutral-500 text-xs uppercase tracking-widest mt-1">Status</div>' +
          '</div>' +
        '</div>' +
        '<div class="mb-8">' +
          '<h3 class="font-heading text-lg font-semibold tracking-tight mb-3">Sinopsis</h3>' +
          '<p class="text-neutral-400 text-sm leading-relaxed">' + anime.desc + '</p>' +
        '</div>' +
        '<div class="mb-8">' +
          '<h3 class="font-heading text-lg font-semibold tracking-tight mb-3">Studio</h3>' +
          '<p class="text-neutral-400 text-sm">' + anime.studio + '</p>' +
        '</div>' +
        '<div class="mb-8">' +
          '<h3 class="font-heading text-lg font-semibold tracking-tight mb-4">Karakter Utama</h3>' +
          '<div class="flex flex-wrap gap-2">' +
            anime.characters.map(function(c) {
              return '<span class="px-3 py-1.5 rounded-full bg-white/[0.03] border border-white/5 text-sm text-neutral-300">' + c + '</span>';
            }).join('') +
          '</div>' +
        '</div>' +
        '<div>' +
          (user
            ? (watched
              ? '<button onclick="unmarkWatched(\'' + anime.title.replace(/'/g, "\\'") + '\')" class="w-full py-3 rounded-xl text-xs font-bold uppercase tracking-widest text-green-400 border border-green-400/30 hover:bg-green-400/10 transition inline-flex items-center justify-center gap-2"><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Sudah Ditonton — Hapus Tanda</button>'
              : '<button onclick="markWatched(\'' + anime.title.replace(/'/g, "\\'") + '\')" class="btn-primary w-full py-3 rounded-xl text-xs font-bold uppercase tracking-widest text-white inline-flex items-center justify-center gap-2"><iconify-icon icon="solar:eye-bold"></iconify-icon> Tandai Sudah Ditonton</button>'
            )
            : '<button onclick="openModal(\'login\')" class="btn-primary w-full py-3 rounded-xl text-xs font-bold uppercase tracking-widest text-white inline-flex items-center justify-center gap-2"><iconify-icon icon="solar:login-bold"></iconify-icon> Masuk untuk Tandai Ditonton</button>'
          ) +
        '</div>';
      showSection('detail');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function markWatched(title) {
      var user = getCurrentUser();
      if (!user) return;
      var db = getDB();
      var exists = db.find(function(d) { return d.email === user.email && d.anime === title; });
      if (!exists) {
        db.push({ email: user.email, anime: title, date: new Date().toISOString() });
        saveDB(db);
        showToast('Anime ditandai sudah ditonton!', 'success');
        showAnimeDetail(title);
      }
    }

    function unmarkWatched(title) {
      var user = getCurrentUser();
      if (!user) return;
      var db = getDB();
      db = db.filter(function(d) { return !(d.email === user.email && d.anime === title); });
      saveDB(db);
      showToast('Tanda ditonton dihapus.', 'info');
      showAnimeDetail(title);
    }

    function playEpisode(ep) {
      var user = getCurrentUser();
      if (user) {
        showToast('Memutar Episode ' + ep + '...', 'success');
      } else {
        showToast('Silakan masuk terlebih dahulu untuk menonton.', 'warning');
        openModal('login');
      }
    }

    // ===================== SECTIONS =====================
    function showSection(section) {
      document.getElementById('sectionHome').classList.add('hidden');
      document.getElementById('sectionDetail').classList.add('hidden');
      if (section === 'home') {
        document.getElementById('sectionHome').classList.remove('hidden');
      } else if (section === 'detail') {
        document.getElementById('sectionDetail').classList.remove('hidden');
      }
    }

    // ===================== MODALS =====================
    function openModal(name) {
      var modal = document.getElementById(name + 'Modal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
    function closeModal(name) {
      var modal = document.getElementById(name + 'Modal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
      var errEl = document.getElementById(name === 'login' ? 'loginError' : 'regError');
      if (errEl) { errEl.classList.add('hidden'); errEl.textContent = ''; }
    }
    function switchModal(from, to) {
      closeModal(from);
      setTimeout(function() { openModal(to); }, 150);
    }

    function toggleMobileMenu() {
      var menu = document.getElementById('mobileMenu');
      if (menu.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        menu.classList.add('flex');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.add('hidden');
        menu.classList.remove('flex');
        document.body.style.overflow = '';
      }
    }

    function togglePassword(id) {
      var input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
    }

    // ===================== AUTH =====================
    function handleLogin(e) {
      e.preventDefault();
      var email = document.getElementById('loginEmail').value.trim();
      var password = document.getElementById('loginPassword').value;
      var errEl = document.getElementById('loginError');
      var db = getDB();
      var user = db.find(function(u) { return u.email === email; });
      if (!user) {
        errEl.textContent = 'Akun tidak ditemukan. Silakan daftar terlebih dahulu.';
        errEl.classList.remove('hidden');
        return;
      }
      if (user.password !== password) {
        errEl.textContent = 'Password salah. Coba lagi.';
        errEl.classList.remove('hidden');
        return;
      }
      setCurrentUser({ username: user.username, email: user.email, favAnime: user.favAnime, registeredAt: user.registeredAt });
      closeModal('login');
      showToast('Selamat datang, ' + user.username + '!', 'success');
      document.getElementById('loginEmail').value = '';
      document.getElementById('loginPassword').value = '';
    }

    function handleRegister(e) {
      e.preventDefault();
      var username = document.getElementById('regUsername').value.trim();
      var email = document.getElementById('regEmail').value.trim();
      var password = document.getElementById('regPassword').value;
      var favAnime = document.getElementById('regFavAnime').value;
      var errEl = document.getElementById('regError');
      var db = getDB();
      var exists = db.find(function(u) { return u.email === email; });
      if (exists) {
        errEl.textContent = 'Email sudah terdaftar. Silakan masuk.';
        errEl.classList.remove('hidden');
        return;
      }
      var newUser = {
        username: username,
        email: email,
        password: password,
        favAnime: favAnime,
        registeredAt: new Date().toISOString()
      };
      db.push(newUser);
      saveDB(db);
      setCurrentUser({ username: username, email: email, favAnime: favAnime, registeredAt: newUser.registeredAt });
      closeModal('register');
      showToast('Akun berhasil dibuat! Selamat datang, ' + username + '!', 'success');
      document.getElementById('regUsername').value = '';
      document.getElementById('regEmail').value = '';
      document.getElementById('regPassword').value = '';
    }

    function handleLogout() {
      var user = getCurrentUser();
      setCurrentUser(null);
      closeModal('profile');
      showToast('Sampai jumpa, ' + (user ? user.username : '') + '!', 'info');
      showSection('home');
    }

    function updateNavAuth() {
      var nav = document.getElementById('navAuth');
      var user = getCurrentUser();
      if (user) {
        nav.innerHTML = '<button onclick="openProfile()" class="flex items-center gap-2 btn-outline px-4 py-2 rounded-full text-xs font-semibold uppercase tracking-widest text-neutral-300">' +
          '<div class="w-6 h-6 rounded-full bg-gradient-to-br from-purple-500 to-blue-600 flex items-center justify-center text-[10px] font-bold">' + user.username.charAt(0).toUpperCase() + '</div>' +
          '<span class="hidden sm:inline">' + user.username + '</span>' +
        '</button>';
      } else {
        nav.innerHTML = '<button onclick="openModal(\'login\')" class="btn-primary text-xs font-semibold uppercase tracking-widest text-white px-5 py-2 rounded-full">Masuk</button>';
      }
    }

    function openProfile() {
      var user = getCurrentUser();
      if (!user) return;
      var db = getDB();
      var watchedCount = db.filter(function(d) { return d.email === user.email && d.anime; }).length;
      document.getElementById('profileAvatar').textContent = user.username.charAt(0).toUpperCase();
      document.getElementById('profileName').textContent = user.username;
      document.getElementById('profileEmail').textContent = user.email;
      document.getElementById('profileFav').textContent = user.favAnime || '-';
      document.getElementById('profileWatched').textContent = watchedCount;
      document.getElementById('profileDate').textContent = user.registeredAt ? new Date(user.registeredAt).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) : '-';
      openModal('profile');
    }

    // ===================== TOAST =====================
    function showToast(message, type) {
      var container = document.getElementById('toastContainer');
      var colors = {
        success: 'border-green-500/30 bg-green-500/10 text-green-300',
        warning: 'border-yellow-500/30 bg-yellow-500/10 text-yellow-300',
        info: 'border-blue-500/30 bg-blue-500/10 text-blue-300',
        error: 'border-red-500/30 bg-red-500/10 text-red-300'
      };
      var icons = {
        success: 'solar:check-circle-bold',
        warning: 'solar:danger-triangle-bold',
        info: 'solar:info-circle-bold',
        error: 'solar:close-circle-bold'
      };
      var toast = document.createElement('div');
      toast.className = 'toast flex items-center gap-3 px-4 py-3 rounded-xl border backdrop-blur-sm text-sm ' + (colors[type] || colors.info);
      toast.innerHTML = '<iconify-icon icon="' + (icons[type] || icons.info) + '" class="text-lg shrink-0"></iconify-icon><span>' + message + '</span>';
      container.appendChild(toast);
      setTimeout(function() {
        toast.style.transition = 'all 0.3s ease';
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(100px)';
        setTimeout(function() { toast.remove(); }, 300);
      }, 3000);
    }

    // ===================== CLOSE MODAL ON OVERLAY CLICK =====================
    document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) {
          var id = overlay.id.replace('Modal', '');
          closeModal(id);
          if (id === '' || overlay.id === 'mobileMenu') {
            toggleMobileMenu();
          }
        }
      });
    });

    // ===================== INIT =====================
    renderAnimeGrid();
    renderCharacters();
    renderEpisodes('naruto');
    updateNavAuth();
  </script>

</body>
</html>
